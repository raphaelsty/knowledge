{$DOMAIN:localhost} {
	# Knowledge API — all backend routes
	handle /indices/* {
		reverse_proxy knowledge-api:8080
	}

	handle /api/* {
		reverse_proxy knowledge-api:8080
	}

	handle /events {
		reverse_proxy knowledge-api:8080
	}

	handle /stats/* {
		reverse_proxy knowledge-api:8080
	}

	# Static frontend files
	handle {
		root * /web
		try_files {path} /index.html
		file_server
	}
}
