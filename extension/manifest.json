{
  "manifest_version": 3,
  "name": "Knowledge Bookmark",
  "version": "1.0.0",
  "description": "Save the current page to your Knowledge base with one click.",
  "permissions": ["activeTab", "scripting", "storage"],
  "browser_specific_settings": {
    "gecko": {
      "id": "knowledge-bookmark@knowledge-web.org",
      "strict_min_version": "109.0"
    }
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "128": "icons/icon-128.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "128": "icons/icon-128.png"
  }
}
